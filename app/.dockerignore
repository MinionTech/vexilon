# Exclude large cache and metadata directories from docker build context
.git/
.github/
hf_cache/
# The FAISS index and chunks are built inside the image via a RUN step in
# the Containerfile; they don't need to be in the build context.
.pdf_cache/

# Standard Python ignores
__pycache__/
*.pyc
.venv/
.pytest_cache/
.coverage

# Exclude local scratchpads and workspaces
.workspaces/
.tmp/
